# ─── REQUIRED ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DATABASE_URL=postgres://user:password@host:5432/dbname

# Gemini API keys — supports 21 keys total for rotation (more keys = higher free quota)
GEMINI_API_KEY=your_primary_gemini_key
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
GEMINI_API_KEY_8=
GEMINI_API_KEY_9=
GEMINI_API_KEY_10=
GEMINI_API_KEY_11=
GEMINI_API_KEY_12=
GEMINI_API_KEY_13=
GEMINI_API_KEY_14=
GEMINI_API_KEY_15=
GEMINI_API_KEY_16=
GEMINI_API_KEY_17=
GEMINI_API_KEY_18=
GEMINI_API_KEY_19=
GEMINI_API_KEY_20=

# ─── HEROKU WEBHOOK (pick one) ───────────────────────────────────
# Option A: set HEROKU_APP_NAME and webhook is auto-detected
HEROKU_APP_NAME=your-heroku-app-name
# Option B: set full webhook URL explicitly (overrides all auto-detection)
# WEBHOOK_URL=https://your-heroku-app-name.herokuapp.com

# ─── ADMIN DASHBOARD ─────────────────────────────────────────────
DASHBOARD_PASSWORD=choose_a_secure_password
SESSION_SECRET=random_secret_for_flask_sessions

# ─── OPTIONAL: PAYMENTS (Paytm UPI) ─────────────────────────────
PAYTM_MERCHANT_ID=your_paytm_merchant_id
PAYTM_MERCHANT_KEY=your_paytm_merchant_key
PAYTM_UPI_ID=yourname@paytm

# ─── OPTIONAL: FORCE SUBSCRIPTION ───────────────────────────────
# Telegram channel username (without @) users must join before chatting
FORCE_SUB_CHANNEL=your_channel_username
