{
  "name": "Keerthana AI - Telegram Girlfriend Bot",
  "description": "Telegram AI girlfriend bot powered by Google Gemini with Tanglish conversation, referral system, and UPI payments.",
  "keywords": ["telegram", "bot", "ai", "gemini", "python"],
  "repository": "https://github.com/Teamhapp/Aigirlfriend",
  "logo": "",
  "success_url": "/",
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ],
  "addons": [
    {
      "plan": "heroku-postgresql:essential-0",
      "as": "DATABASE"
    }
  ],
  "env": {
    "TELEGRAM_BOT_TOKEN": {
      "description": "Your Telegram Bot token from @BotFather",
      "required": true
    },
    "GEMINI_API_KEY": {
      "description": "Primary Google Gemini API key — get free at aistudio.google.com",
      "required": true
    },
    "GEMINI_API_KEY_1": {
      "description": "Optional: 2nd Gemini key for rotation (higher quota)",
      "required": false
    },
    "GEMINI_API_KEY_2": {
      "description": "Optional: 3rd Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_3": {
      "description": "Optional: 4th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_4": {
      "description": "Optional: 5th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_5": {
      "description": "Optional: 6th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_6": {
      "description": "Optional: 7th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_7": {
      "description": "Optional: 8th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_8": {
      "description": "Optional: 9th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_9": {
      "description": "Optional: 10th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_10": {
      "description": "Optional: 11th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_11": {
      "description": "Optional: 12th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_12": {
      "description": "Optional: 13th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_13": {
      "description": "Optional: 14th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_14": {
      "description": "Optional: 15th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_15": {
      "description": "Optional: 16th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_16": {
      "description": "Optional: 17th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_17": {
      "description": "Optional: 18th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_18": {
      "description": "Optional: 19th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_19": {
      "description": "Optional: 20th Gemini key for rotation",
      "required": false
    },
    "GEMINI_API_KEY_20": {
      "description": "Optional: 21st Gemini key for rotation",
      "required": false
    },
    "HEROKU_APP_NAME": {
      "description": "Your Heroku app name exactly as shown in the URL (e.g. my-app-name). Used to auto-register the Telegram webhook.",
      "required": true
    },
    "DASHBOARD_PASSWORD": {
      "description": "Password to access the admin dashboard at /dashboard",
      "required": true
    },
    "SESSION_SECRET": {
      "description": "Random secret for Flask session encryption",
      "generator": "secret",
      "required": true
    },
    "FORCE_SUB_CHANNEL": {
      "description": "Optional: Telegram channel username (without @) users must join before chatting",
      "required": false
    },
    "PAYTM_MERCHANT_ID": {
      "description": "Optional: Paytm merchant ID for UPI payment auto-verification",
      "required": false
    },
    "PAYTM_MERCHANT_KEY": {
      "description": "Optional: Paytm merchant key",
      "required": false
    },
    "PAYTM_UPI_ID": {
      "description": "Optional: Your UPI ID for receiving payments (e.g. yourname@paytm)",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "eco"
    }
  }
}
