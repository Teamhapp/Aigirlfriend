modules = ["python-3.11"]
[agent]
expertMode = true
integrations = ["python_gemini:1.0.0", "python_database:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Keerthana Bot"

[[workflows.workflow]]
name = "Keerthana Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--workers=2", "--timeout=120", "app:app"]

[userenv]

[userenv.production]
WEBHOOK_URL = "https://workspace-naamokojaanohi.replit.app"
